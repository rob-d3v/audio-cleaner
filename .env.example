# Copie para .env e ajuste. Todas as variáveis usam o prefixo AUDIO_CLEANER_.

# Onde a biblioteca do usuário é salva (projetos, takes, letras, prompts).
# Padrão: %LOCALAPPDATA%/AudioCleaner (Windows) via platformdirs.
# AUDIO_CLEANER_DATA_DIR=./data

# Host/porta do servidor.
# AUDIO_CLEANER_HOST=127.0.0.1
# AUDIO_CLEANER_PORT=8000

# Liga o auto-reload do uvicorn em desenvolvimento (1 = ligado).
# AUDIO_CLEANER_RELOAD=0
