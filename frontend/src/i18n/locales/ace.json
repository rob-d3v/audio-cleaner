  "scripts": {
    "suno_voice_full": {
      "name": "Naskah vokal lengkap keu Suno .",
      "desc": "5 minet nyang geubimbing: pemanasan, vokal, skala, dua boh peutimang lagu, dinamika, dan saboh frasa nyang geupeugah."
    },
    "step": {
      "warmup": "Peumanasan vokal",
      "warmup_inst": "Peulonggar ngon kuah, bibi trill (brrr), dan hum lembut seulama kira-kira si minet. Hana peurlee rekam — nyan cuma untuk relaksasi jaroe sigohlom meulagu.",
      "vowels": "Vokal nyang meulanjut",
      "vowels_inst": "Peutheun tiep-tiep vokal — a, e, i, o, u — seulama 3 sampoe 4 detik bak nada nyang nyaman, ngon volume nyang teutap. Nyoe meubantu Suno jicok timbre murni su droeneuh.",
      "scales": "Timbangan ateuh ngon miyueb .",
      "scales_inst": "Meulagukan skala sederhana ateuh ngen lheuhnyan miyup, bak \"la\" atau \"na\". Hana peureulee sempurna — tujuan jih nakeuh untuk tapeugot peta jangkauan vokal droe.",
      "section": "Peutimang lagu — bagian 1 .",
