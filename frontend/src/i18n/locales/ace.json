  "guide": {
    "title": "Panduan rekaman Suno .",
    "subtitle": "Cara capture suara dan gitar takes yang meurumpok hasil yang paleng get.",
    "intro": "Suno berprestasi paleng get deungon referensi nyang gleh dan hana ambigu. Panduan nyoe mencakup persiapan, tingkat target, dan naskah rekaman 3-5 minet.",
    "sections": {
      "prep": {
        "title": "Peusiapan",
        "body": "Catat lam kama nyang dirawat atawa nyang le bahan leumbot (tirai, permadani, bajee lam lemari). Padamkan kipas dan apapun yang menggema. Peusuum su droe 5 minet sigohlom rekaman."
      },
      "levels": {
        "title": "Tingkat: -12 sampoe -6 dBFS",
        "body": "Tujuan jih puncak antara -12 ngon -6 dBFS bak meter. Di miyup jangkauan nyan, riyoh latar jeuet keu leubeh deuh; di ateuh nyan, resiko kliping naek. Pakèk meter bak laman Rekam keu neu-atur gain droëneuh sigohlom neumulai."
      },
      "distance": {
        "title": "Jarak mikro: 15-30 cm",
        "body": "Tetap 15 sampoe 30 cm dari mikrofon. Leubeh toe nibak nyan geupeuleubeh-leubeh plosif dan efek proximity; leubeh jioh jicok leubeh le reverb ruangan dan riyoh."
      },
      "script": {
        "title": "Rekaman naskah",
        "warmup": "Peumanasan vokal (1-2 minet)",
        "vowels": "Vokal nyang meulanjut — a, e, i, o, u .",
        "scales": "Timbangan sederhana, ateuh ngon miyueb .",
        "excerpt": "Saboh peutimang lagu (8 sampoe 16 bar)",
        "dynamics": "Dinamika: mulai leumoh, akhe kreuh",
        "spoken_phrase": "Saboh frasa nyang dipeugah, supaya Suno jeut geubaca nada vokal droeneuh"
      },
      "expectations": {
        "title": "Peue nyang geuharapkan le Suno .",
        "body": "WAV, 48 kHz, mono, tho (hana reverb atawa efek), 3 sampoe 5 minet acuan. Nyang paleng gleh, paleng meuwakili 2 minet dari take biasajih meuhase hasee nyang paleng get."
      }
    }
