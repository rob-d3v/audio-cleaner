  "scripts": {
    "suno_voice_full": {
      "name": "Naskah vokal lengkap buat Suno",
      "desc": "5 menit yang dipandu: pemanasan, vokal, tangga nada, dua kutipan lagu, dinamika, dan frasa lisan."
    },
    "step": {
      "warmup": "Pemanasan vokal",
      "warmup_inst": "Lepasin dengan nguap, bibir berdesir (brrr), dan bersenandung lembut selama sekitar semenit. Gak perlu ngerekam — cuma buat rileksin tenggorokan sebelum nyanyi.",
      "vowels": "Vokal yang berkelanjutan",
      "vowels_inst": "Tahan tiap vokal — a, e, i, o, u — selama 3 sampe 4 detik dengan nada yang nyaman, dengan volume yang mantap. Ini ngebantu Suno ngambil timbre murni dari suara lu.",
      "scales": "Timbangan naik turun",
      "scales_inst": "Nyanyiin skala sederhana ke atas dan ke bawah, di \"la\" atau \"na\". Gak perlu sempurna — tujuannya adalah buat ngepetain jangkauan vokal lu.",
      "section": "Kutipan lagu — bagian 1",
      "section_inst": "Nyanyiin 8 sampe 16 bar lagu, dengan niat yang mau lu sampein. Prioritaskan kejelasan dan kehadiran daripada kesempurnaan teknis.",
      "section2": "Kutipan lagu — bagian 2",
      "section2_inst": "Nyanyiin 8 sampe 16 bar lagi — idealnya paduan suara atau bagian yang kontras dengan yang sebelumnya. Lebih banyak variasi membantu model belajar suara lu.",
      "dynamics": "Dinamika: lembut → keras",
      "dynamics_inst": "Nyanyiin frasa yang sama, mulai pelan banget dan berakhir keras, tanpa ngeregangin tenggorokan. Ini nunjukin ke Suno jangkauan dinamis suara lu.",
      "spoken": "Frasa yang diucapin",
      "spoken_inst": "Ngomong — jangan nyanyi — kalimat singkat dan alami, seolah-olah lu lagi ngobrol. Ini ngebantu Suno ngenalin timbre asli dari suara lu."
    }
  },
