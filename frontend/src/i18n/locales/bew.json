  "guide": {
    "title": "Panduan rekaman Suno",
    "subtitle": "Cara ngambil suara dan gitar yang dapet hasil terbaik.",
    "intro": "Suno paling bagus dengan referensi yang bersih dan jelas. Panduan ini mencakup persiapan, tingkat target, dan naskah rekaman 3-5 menit.",
    "sections": {
      "prep": {
        "title": "Persiapan",
        "body": "Rekam di ruangan yang udah dirawat atau yang banyak bahan lembut (tirai, karpet, baju di lemari). Matiin kipas angin dan apapun yang berdengung. Angetin suara lu selama 5 menit sebelum ngerekam."
      },
      "levels": {
        "title": "Tingkat: -12 sampe -6 dBFS",
        "body": "Tujuanin puncak antara -12 dan -6 dBFS di meter. Di bawah rentang itu, kebisingan latar jadi lebih kerasa; di atasnya, resiko kliping naik. Pake meteran di halaman Rekam buat ngatur keuntungan lu sebelum lu mulai."
      },
      "distance": {
        "title": "Jarak mikrofon: 15-30 cm",
        "body": "Jauh 15 sampe 30 cm dari mikrofon. Lebih deket dari itu melebih-lebihkan plosif dan efek kedekatan; lebih jauh ngambil lebih banyak gema ruangan dan noise."
      },
      "script": {
        "title": "Naskah rekaman",
        "warmup": "Pemanasan vokal (1-2 menit)",
        "vowels": "Vokal berkelanjutan — a, e, i, o, u",
        "scales": "Timbangan sederhana, naik turun",
        "excerpt": "Kutipan lagu (8 sampe 16 bar)",
        "dynamics": "Dinamika: mulai lembut, akhir kenceng",
        "spoken_phrase": "Satu kalimat yang diucapin, biar Suno bisa baca nada vokal lu"
      },
      "expectations": {
        "title": "Apa yang Suno harapkan",
        "body": "WAV, 48 kHz, mono, kering (kagak ada gema atau efek), 3 sampe 5 menit referensi. menit yang paling bersih dan paling representatif dari pengambilan biasanya menghasilkan hasil yang paling bagus."
      }
    }
  },
  "status": {
    "idea": "Ide",
