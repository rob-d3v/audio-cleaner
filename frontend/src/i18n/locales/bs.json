  "guide": {
    "title": "Suno vodič za snimanje",
    "subtitle": "Kako snimiti glasovne i gitarske snimke koji postižu najbolje rezultate.",
    "intro": "Suno najbolje radi sa čistim, nedvosmislenim referencama. Ovaj vodič pokriva pripremu, ciljne nivoe i skriptu za snimanje od 3-5 minuta.",
    "sections": {
      "prep": {
        "title": "Priprema",
        "body": "Snimajte u tretiranoj prostoriji ili prostoriji sa dosta mekog materijala (zavjese, prostirke, odjeća u ormaru). Isključite ventilatore i sve što bruji. Zagrijte svoj glas 5 minuta prije snimanja."
      },
      "levels": {
        "title": "Nivoi: -12 do -6 dBFS",
        "body": "Ciljajte na vrhove između -12 i -6 dBFS na mjeraču. Ispod tog opsega, pozadinska buka postaje uočljivija; iznad nje raste rizik od rezanja. Koristite mjerač na stranici za snimanje da biste podesili pojačanje prije nego što počnete."
      },
      "distance": {
        "title": "Udaljenost mikrofona: 15–30 cm",
        "body": "Držite se 15 do 30 cm od mikrofona. Bliže od toga preuveličava eksplozivnost i efekat blizine; dalje hvata više sobnog reverba i šuma."
      },
      "script": {
        "title": "Skripta za snimanje",
        "warmup": "Vokalno zagrijavanje (1-2 minute)",
        "vowels": "Trajni samoglasnici - a, e, i, o, u",
        "scales": "Jednostavne vage, gore i dolje",
        "excerpt": "Odlomak pjesme (8 do 16 taktova)",
        "dynamics": "Dinamika: počni tiho, završi glasno",
        "spoken_phrase": "Jedna izgovorena fraza, tako da Suno može pročitati vaš vokalni ton"
      },
      "expectations": {
        "title": "Šta Suno očekuje",
        "body": "WAV, 48 kHz, mono, suvo (bez reverba ili efekata), 3 do 5 minuta reference. Najčistije, najreprezentativnije 2 minute uzimanja obično daju najbolje rezultate."
      }
    }
  },
