  "scripts": {
    "suno_voice_full": {
      "name": "Cijeli vokalni scenario za Suno",
      "desc": "5 vođenih minuta: zagrijavanje, samoglasnici, ljestvice, dva odlomka pjesama, dinamika i izgovorena fraza."
    },
    "step": {
      "warmup": "Vokalno zagrijavanje",
      "warmup_inst": "Opustite se zijevanjem, trepetovima usana (brrr) i tihim pjevušenjem oko minutu. Nema potrebe za snimanjem – to je samo da opustite grlo prije pjevanja.",
      "vowels": "Trajni samoglasnici",
      "vowels_inst": "Držite svaki samoglasnik — a, e, i, o, u — 3 do 4 sekunde na vašoj udobnoj visini, uz stabilnu jačinu zvuka. Ovo pomaže Sunou da pokupi čisti tembar vašeg glasa.",
      "scales": "Skala gore i dolje",
      "scales_inst": "Pjevajte jednostavnu ljestvicu gore, a zatim dolje, na \"la\" ili \"na\". Ne mora biti savršen – cilj je mapirati vaš vokalni raspon.",
