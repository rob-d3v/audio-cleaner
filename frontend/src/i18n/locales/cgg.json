  "guide": {
    "title": "Omuhabuzi w'okuteera akatambi ka Suno",
    "subtitle": "Oku orikubaasa kukwata eiraka n’okuteera gitaara ebirikutwara ebirungi.",
    "intro": "Suno neekora gye n’ebihandiiko ebishemeire kandi ebitarikubanganisa. Endagiiriro egi neekwata aha kutebeekanisa, emiringo y‘okugyenderaho, n‘ekihandiiko ky‘okuhandiika eky‘edakiika 3–5.",
    "sections": {
      "prep": {
        "title": "Okutebeekanisa",
        "body": "Rekodi omu kishengye ekijanjabirwe nari ekirimu ebintu bingi ebigumire (emikingo, ebitanda, emyenda omu kabada). Zima abakunzi n'ekintu kyona ekirikuhurira. Okwotsya eiraka ryawe kumara edakiika 5 otakakwatsire."
      },
      "levels": {
        "title": "Emiringo: -12 kuhika -6 dBFS",
        "body": "Ekigyendererwa ky‘okutunga enshonga eziri ahagati ya -12 na -6 dBFS aha mita. Ahansi y’omubaro ogwo, oruyombo oruri enyima nirukira kweyoreka; ahaiguru yaayo, akabi k‘okusharaho nikeeyongyera. Kozesa mita eri aha rupapura rwa Record kutebeekanisa omugasho gwawe otakatandikire."
      },
