  "guide": {
    "title": "Průvodce nahráváním Suno",
    "subtitle": "Jak zachytit hlas a kytaru, které dosáhnou nejlepších výsledků.",
    "intro": "Suno si nejlépe vede s čistými, jednoznačnými referencemi. Tento průvodce pokrývá přípravu, cílové úrovně a 3–5minutový scénář nahrávání.",
    "sections": {
      "prep": {
        "title": "Příprava",
        "body": "Nahrávejte v ošetřované místnosti nebo v místnosti s dostatkem měkkého materiálu (záclony, koberečky, oblečení ve skříni). Vypněte ventilátory a vše, co hučí. Před nahráváním zahřejte svůj hlas po dobu 5 minut."
      },
      "levels": {
        "title": "Úrovně: -12 až -6 dBFS",
        "body": "Zaměřte se na špičky mezi -12 a -6 dBFS na měřiči. Pod tímto rozsahem je šum pozadí znatelnější; nad ním se zvyšuje riziko oříznutí. Než začnete, použijte měřič na stránce Record k nastavení svého zisku."
      },
      "distance": {
        "title": "Vzdálenost mikrofonu: 15–30 cm",
        "body": "Zůstaňte 15 až 30 cm od mikrofonu. Bližší než to přehání výbušniny a efekt blízkosti; dále zachytí více prostorového dozvuku a hluku."
      },
      "script": {
        "title": "Nahrávací skript",
        "warmup": "Vokální rozcvička (1–2 minuty)",
        "vowels": "Trvalé samohlásky — a, e, i, o, u",
        "scales": "Jednoduché váhy, nahoru a dolů",
        "excerpt": "Úryvek písně (8 až 16 taktů)",
        "dynamics": "Dynamika: začátek jemně, konec hlasitý",
        "spoken_phrase": "Jedna mluvená fráze, takže Suno může přečíst váš hlasový tón"
      },
      "expectations": {
        "title": "Co Suno očekává",
        "body": "WAV, 48 kHz, mono, suché (bez reverbu nebo efektů), 3 až 5 minut reference. Nejčistší a nejreprezentativnější 2 minuty užívání obvykle poskytují nejlepší výsledky."
      }
