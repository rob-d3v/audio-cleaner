  "guide": {
    "title": "Malailile aakulekkooda aa Suno",
    "subtitle": "Mbuti mbomukonzya kujata jwi a gitala kuti zipe mpindu zibotu.",
    "intro": "Suno ulachita obotu kwiinda mukubelesya zitondezyo zisalala, zitakwe kudooneka. Bbuku eeli lijatikizya kulibambila, zyeelelo, antoomwe a script yakulekkooda yamaminiti aali 3-5.",
    "sections": {
      "prep": {
        "title": "Kulibambila",
        "body": "Lekkooda mukaanda kasalala naakuti kajisi zintu zinji ziteteete (maketeni, mabbaaji, zizwaato zili muchibbeeke). Zima mafeni azintu zyoonse zivwuuma. Bikka jwi lyako kwamaminiti aali 5 kotana lekkooda."
      },
      "levels": {
        "title": "Ziimo: -12 kusika ku -6 dBFS",
        "body": "Kosola kusika aakati ka -12 a -6 dBFS aamita. Munsi aachiimo eecho, muzuzumo wakusyule ulaboneka loko; atala lyawo, ntenda yakugela ilatanta. Belesya mita apeeji lyakulekkooda kubikka mpindu yako kotana talika."
      },
      "distance": {
        "title": "Kulampa kwa maikkulofooni: 15-30 cm",
        "body": "Kokkala 15 kusikila ku 30 cm kuzwa kumaikkulofooni. Kuswena afwaafwi kwiinda waawo kulayungizya ma plosives a proximity effect; kulaale kulatola muzuzumo mupati."
      },
      "script": {
        "title": "Kulekkooda lugwalo",
        "warmup": "Kubamba jwi (1-2 maminiti)",
        "vowels": "Mavowela aatamani — a, e, i, o, u",
        "scales": "Zipimyo zitakatazyi, kuya mujulu akuseluka",
        "excerpt": "Chibeela chalwiimbo (8 kusikila ku 16 bars)",
        "dynamics": "Kuchincha: kutalika chakufwambaana, kumanizya chakupozomoka",
        "spoken_phrase": "Ijwi lyomwe lyaambwa, kuchitila kuti Suno akonzye kubala jwi lyako"
      },
