      "warmup_inst": "ގާތްގަނޑަކަށް މިނިޓެއްހާއިރު ޔޯންސް، ލިޕް ޓްރިލްސް (brrr)، އަދި މަޑު ހޫމް އެއް ޖަހައިގެން ލުއިކޮށްލާށެވެ. ރެކޯޑް ކުރަން ނުޖެހޭ — އެއީ ހަމައެކަނި ލަވަކިޔުމުގެ ކުރިން ކަރު ރިލެކްސް ކުރުމަށެވެ.",
      "vowels": "ދެމެހެއްޓެނިވި ވައަލްތަކެވެ",
      "vowels_inst": "ކޮންމެ ވައަލްއެއް — އޭ، އީ، އައި، އޯ، ޔޫ — ތިމާގެ އަރާމު ޕިޗްގައި، އެއްވަރަކަށް އަޑުގަދަކޮށް، 3 އާއި 4 ސިކުންތަށް ހިފަހައްޓާށެވެ. މިއީ ސުނޯއަށް ތިބާގެ އަޑުގެ ސާފު ޓިމްބަރ ނަގަން އެހީތެރިވެދޭ ކަމެކެވެ.",
      "scales": "މައްޗަށް ތިރިއަށް ސްކޭލް ކުރެއެވެ",
      "scales_inst": "ސާދާ ސްކޭލެއް މައްޗަށް އަދި ދެން ތިރިއަށް، \"ލާ\" ނުވަތަ \"ނާ\" ގައި ލަވަކިޔާށެވެ. އެއީ ފުރިހަމަ އެއްޗަކަށް ވާކަށް ނުޖެހޭ — އަމާޒަކީ ތިމާގެ ވޯކަލް ރޭންޖް މެޕް ކުރުމެވެ.",
      "section": "ލަވައިގެ ބައެއް — 1 ވަނަ ބައި",
      "section_inst": "ލަވައިގެ 8 ބާރާއި 16 ބާރާއި ދެމެދުގެ ލަވައެއް ކިޔާ، ތިމާ ފޯރުކޮށްދޭން ބޭނުންވާ އަސްލު ނިޔަތާ އެކު. ފަންނީ ފުރިހަމަކަމަށްވުރެ ސާފުކަމާއި ޙާޟިރީއަށް އިސްކަންދިނުން.",
      "section2": "ލަވައިގެ ބައެއް — 2 ވަނަ ބައި",
      "section2_inst": "އިތުރު 8 އިން 16 ބާރ އަށް ލަވަކިޔުން — އެންމެ ރަނގަޅީ ކޯރަސް ނުވަތަ ކުރީގެ ބާރާއި ތަފާތު ބައެއް. އިތުރު ތަފާތު ކުރުމަކީ މޮޑެލްއަށް ތިބާގެ އަޑު ދަސްކުރުމަށް އެހީތެރިވެދޭ ކަމެކެވެ.",
      "dynamics": "ޑައިނަމިކްސް: މަޑު → އަޑުގަދަ",
      "dynamics_inst": "ވަރަށް މަޑުމަޑުން ފެށިގެން އަޑުގަދަކޮށް ނިންމާލާފައި، ކަރުތެރެއަށް ބުރަ ނުކޮށް ހަމަ އެ ޢިބާރާތް ކިޔާށެވެ. މިކަމުން ސުނޯއަށް ތިބާގެ އަޑުގެ ޑައިނަމިކް ރޭންޖް ފެނެއެވެ.",
      "spoken": "ވާހަކަ ދައްކާ ޢިބާރާތެވެ",
      "spoken_inst": "ވާހަކަ ދައްކާ — ލަވަ ނުކިޔަވާ — ކުރު، ގުދުރަތީ ޢިބާރާތެއް، ޗެޓް ކުރާ ފަދައިންނެވެ. މިއީ ސުނޯއަށް ތިބާގެ އަޑުގެ އަސްލު ޓިމްބަރ ދެނެގަތުމަށް އެހީތެރިވެދޭ ކަމެކެވެ."
