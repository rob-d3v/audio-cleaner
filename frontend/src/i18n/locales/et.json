  "guide": {
    "title": "Suno salvestusjuhend",
    "subtitle": "Kuidas jäädvustada häält ja kitarri, mis annavad parimaid tulemusi.",
    "intro": "Suno toimib kõige paremini puhaste ja ühemõtteliste viidetega. See juhend hõlmab ettevalmistust, sihttasemeid ja 3–5-minutilist salvestusskripti.",
    "sections": {
      "prep": {
        "title": "Ettevalmistus",
        "body": "Salvestage töödeldud ruumis või ruumis, kus on palju pehmet materjali (kardinad, vaibad, riided kapis). Lülitage välja ventilaatorid ja kõik, mis sumiseb. Enne salvestamist soojendage oma häält 5 minutit."
      },
      "levels": {
        "title": "Tasemed: -12 kuni -6 dBFS",
        "body": "Püüdke mõõtja piike vahemikus -12 kuni -6 dBFS. Sellest vahemikust allpool muutub taustmüra märgatavamaks; sellest kõrgemal tõuseb lõikamisrisk. Enne alustamist kasutage kasumi määramiseks lehel Record mõõdikut."
      },
      "distance": {
        "title": "Mikrofoni kaugus: 15–30 cm",
        "body": "Jääge mikrofonist 15–30 cm kaugusele. See liialdab lõhkeainete ja lähedusefektiga; kaugemal võtab rohkem ruumi kaja ja müra."
      },
      "script": {
        "title": "Skripti salvestamine",
        "warmup": "Hääle soojendus (1-2 minutit)",
        "vowels": "Jätkuvad vokaalid — a, e, i, o, u",
        "scales": "Lihtsad kaalud, üles ja alla",
        "excerpt": "Katkend laulust (8-16 takti)",
        "dynamics": "Dünaamika: alusta vaikselt, lõpeta valjult",
        "spoken_phrase": "Üks öeldud fraas, et Suno saaks teie hääletooni lugeda"
      },
      "expectations": {
        "title": "Mida Suno ootab",
        "body": "WAV, 48 kHz, mono, kuiv (ilma kaja ega efektideta), 3–5 minutit võrdlusalust. Kõige puhtam ja esinduslikum 2 minutit võtet annab tavaliselt parimad tulemused."
      }
    }
  },
  "status": {
    "idea": "Idee",
    "em_progresso": "Pooleli",
    "quase": "Peaaegu kohal",
    "pronto": "Valmis"
  },
  "scripts": {
    "suno_voice_full": {
      "name": "Suno täielik vokaalstsenaarium",
      "desc": "5 juhendatud minutit: soojendus, täishäälikud, skaalad, kaks laulukatket, dünaamika ja öeldud fraas."
    },
    "step": {
      "warmup": "Vokaal soojendus",
      "warmup_inst": "Lõdvestuge haigutuste, huulte trillide (brrr) ja pehme suminaga umbes minuti jooksul. Pole vaja salvestada – see on lihtsalt selleks, et enne laulmist kõri lõdvestada.",
      "vowels": "Püsivad vokaalid",
      "vowels_inst": "Hoidke iga vokaali – a, e, i, o, u – 3–4 sekundit oma mugaval kõrgusel ja ühtlase helitugevusega. See aitab Sunol tuvastada teie hääle puhta tämbri.",
      "scales": "Kaalud üles ja alla",
      "scales_inst": "Laulge lihtsal skaalal üles ja siis alla, kas \"la\" või \"na\". See ei pea olema täiuslik – eesmärk on kaardistada teie hääleulatus.",
      "section": "Laulu katkend — 1. osa",
      "section_inst": "Laulge laulu 8–16 takti tõelise kavatsusega, mida soovite edasi anda. Eelistage selgust ja kohalolekut tehnilisele täiuslikkusele.",
      "section2": "Laulu katkend — 2. osa",
      "section2_inst": "Laulge veel 8–16 takti – ideaaljuhul refrään või sektsioon, mis on kontrastiks eelmisega. Suurem mitmekesisus aitab modellil teie häält õppida.",
      "dynamics": "Dünaamika: pehme → vali",
