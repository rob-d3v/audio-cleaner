  "guide": {
    "title": "Suno grabatzeko gida",
    "subtitle": "Nola atera emaitzarik onenak lortzen dituzten ahotsa eta gitarra.",
    "intro": "Suno erreferentzi garbi eta anbiguoekin egiten da onena. Gida honek prestaketa, helburu-mailak eta 3-5 minutuko grabazio-gidoia biltzen ditu.",
    "sections": {
      "prep": {
        "title": "Prestaketa",
        "body": "Grabatu tratatutako gela batean edo material leun asko duen batean (gortinak, alfonbrak, arropa armairu batean). Itzali haizagailuak eta burrunba egiten duen edozer. Berotu ahotsa 5 minutuz grabatu aurretik."
      },
      "levels": {
        "title": "Mailak: -12 eta -6 dBFS",
        "body": "Helburua neurgailuaren -12 eta -6 dBFS arteko gailurrak. Tarte horretatik behera, hondoko zarata nabariagoa bihurtzen da; gainetik, mozketa arriskua igotzen da. Erabili Grabatu orrialdeko neurgailua hasi aurretik irabazia ezartzeko."
      },
      "distance": {
        "title": "Mikroaren distantzia: 15-30 cm",
        "body": "Egon mikrofonotik 15 eta 30 cm-ra. Hori baino hurbilago esplosiboak eta hurbiltasun efektua areagotzen ditu; urrunago gela erreberb eta zarata gehiago jasotzen du."
      },
      "script": {
        "title": "Grabaketa gidoia",
        "warmup": "Ahotsaren beroketa (1-2 minutu)",
        "vowels": "Bokal iraunkorrak - a, e, i, o, u",
        "scales": "Eskala sinpleak, gora eta behera",
        "excerpt": "Abestiaren zati bat (8 eta 16 konpas)",
        "dynamics": "Dinamika: leun hasi, ozen amaitu",
        "spoken_phrase": "Ahozko esaldi bat, Sunok zure ahots-tonua irakur dezan"
      },
      "expectations": {
        "title": "Sunok espero duena",
        "body": "WAV, 48 kHz, mono, lehorra (erreberbrik edo efekturik gabe), 3 eta 5 minutu arteko erreferentzia. Hartutako 2 minutu garbienak eta adierazgarrienak normalean emaitzarik onenak ematen ditu."
      }
    }
  },
