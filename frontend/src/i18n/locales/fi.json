  "scripts": {
    "suno_voice_full": {
      "name": "Sunon täydellinen laulukäsikirjoitus",
      "desc": "5 ohjattua minuuttia: lämmittely, vokaalit, asteikot, kaksi kappaletta, dynamiikka ja puhuttu fraasi."
    },
    "step": {
      "warmup": "Laulun lämmittely",
      "warmup_inst": "Löysää haukotuksella, huuletrillillä (brrr) ja pehmeällä huminalla noin minuutin ajan. Ei tarvitse äänittää - se on vain rentouttaa kurkkua ennen laulamista.",
      "vowels": "Jatkuvat vokaalit",
      "vowels_inst": "Pidä kutakin vokaalia – a, e, i, o, u – 3–4 sekuntia mukavalla äänenkorkeudellasi tasaisella äänenvoimakkuudella. Tämä auttaa Sunoa poimimaan äänesi puhtaan sointin.",
      "scales": "Vaaka ylös ja alas",
