  "guide": {
    "title": "Suno äänitysopas",
    "subtitle": "Äänen ja kitaran vangitseminen tuottaa parhaat tulokset.",
    "intro": "Suno toimii parhaiten puhtailla, yksiselitteisillä viittauksilla. Tämä opas kattaa valmistelun, tavoitetasot ja 3–5 minuutin tallennuskäsikirjoituksen.",
    "sections": {
      "prep": {
        "title": "Valmistelu",
        "body": "Nauhoita käsitellyssä huoneessa tai sellaisessa, jossa on runsaasti pehmeää materiaalia (verhot, matot, vaatteet kaapissa). Sammuta tuulettimet ja kaikki mikä humisee. Lämmitä ääntäsi 5 minuuttia ennen äänitystä."
      },
      "levels": {
        "title": "Tasot: -12 - -6 dBFS",
        "body": "Tavoittele mittarin huippuja välillä -12 ja -6 dBFS. Tämän alueen alapuolella taustamelu tulee havaittavammaksi; sen yläpuolella leikkausriski kasvaa. Käytä Record-sivun mittaria vahvistaaksesi vahvistuksesi ennen aloittamista."
      },
      "distance": {
        "title": "Mikrofonin etäisyys: 15-30 cm",
        "body": "Pysy 15-30 cm päässä mikrofonista. Lähempänä sitä liioittelevat räjähteet ja läheisyysvaikutus; kauempana poimii enemmän huoneen kaikua ja melua."
      },
      "script": {
        "title": "Tallennus käsikirjoitus",
        "warmup": "Laulun lämmittely (1-2 minuuttia)",
        "vowels": "Jatkuvat vokaalit - a, e, i, o, u",
        "scales": "Yksinkertaiset vaa'at, ylös ja alas",
        "excerpt": "Kappalekappale (8-16 tahtia)",
        "dynamics": "Dynamiikka: aloita pehmeästi, lopeta äänekkäästi",
        "spoken_phrase": "Yksi puhuttu lause, jotta Suno voi lukea äänensävysi"
      },
      "expectations": {
        "title": "Mitä Suno odottaa",
        "body": "WAV, 48 kHz, mono, kuiva (ei kaikua tai tehosteita), 3-5 minuuttia referenssiä. Parhaat tulokset tuottavat yleensä puhtain, edustavin 2 minuuttia."
      }
    }
