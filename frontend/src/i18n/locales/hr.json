        "excerpt": "Ulomak pjesme (8 do 16 taktova)",
        "dynamics": "Dinamika: početak tiho, kraj glasno",
        "spoken_phrase": "Jedna izgovorena fraza, tako da Suno može pročitati vaš vokalni ton"
      },
      "expectations": {
        "title": "Što Suno očekuje",
        "body": "WAV, 48 kHz, mono, suho (bez reverba ili efekata), 3 do 5 minuta reference. Najčišće, najreprezentativnije 2 minute snimanja obično daju najbolje rezultate."
      }
    }
