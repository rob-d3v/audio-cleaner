  "guide": {
    "title": "Suno vodič za snimanje",
    "subtitle": "Kako snimiti snimke glasa i gitare koji daju najbolje rezultate.",
    "intro": "Suno ima najbolje rezultate s čistim, nedvosmislenim referencama. Ovaj vodič pokriva pripremu, ciljane razine i skriptu za snimanje od 3 do 5 minuta.",
    "sections": {
      "prep": {
        "title": "Priprema",
        "body": "Snimajte u tretiranoj prostoriji ili u prostoriji s puno mekog materijala (zavjese, prostirke, odjeća u ormaru). Isključite ventilatore i sve što zuji. Zagrijte glas 5 minuta prije snimanja."
      },
      "levels": {
        "title": "Razine: -12 do -6 dBFS",
        "body": "Ciljajte na vršne vrijednosti između -12 i -6 dBFS na mjeraču. Ispod tog raspona, pozadinska buka postaje uočljivija; iznad toga raste rizik od rezanja. Upotrijebite mjerač na stranici Record kako biste postavili dobit prije početka."
      },
      "distance": {
        "title": "Udaljenost mikrofona: 15–30 cm",
        "body": "Ostanite 15 do 30 cm od mikrofona. Bliže od toga preuveličava eksplozive i učinak blizine; dalje hvata više reverba i buke u prostoriji."
      },
      "script": {
        "title": "Scenarij za snimanje",
