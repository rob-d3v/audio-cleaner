  "guide": {
    "title": "Suno upptökuleiðbeiningar",
    "subtitle": "Hvernig á að fanga radd- og gítartak sem ná sem bestum árangri.",
    "intro": "Suno stendur sig best með hreinum, ótvíræðum tilvísunum. Þessi handbók fjallar um undirbúning, markstig og 3–5 mínútna upptökuhandrit.",
    "sections": {
      "prep": {
        "title": "Undirbúningur",
        "body": "Taktu upp í meðhöndluðu herbergi eða með miklu mjúku efni (gardínur, mottur, föt í skáp). Slökktu á viftum og öllu sem raular. Hitaðu röddina í 5 mínútur áður en þú tekur upp."
      },
      "levels": {
        "title": "Stig: -12 til -6 dBFS",
        "body": "Miðaðu við toppa á milli -12 og -6 dBFS á mælinum. Fyrir neðan það svið verður bakgrunnshljóð meira áberandi; fyrir ofan það eykst klippahætta. Notaðu mælinn á Record síðunni til að stilla ávinninginn þinn áður en þú byrjar."
      },
      "distance": {
        "title": "Fjarlægð hljóðnema: 15–30 cm",
        "body": "Vertu 15 til 30 cm frá hljóðnemanum. Nær en það ýkir plosives og nálægðaráhrif; lengra í burtu tekur upp meiri reverb og hávaða."
      },
      "script": {
        "title": "Upptökuhandrit",
        "warmup": "Raddupphitun (1–2 mínútur)",
        "vowels": "Viðvarandi sérhljóðar - a, e, i, o, u",
        "scales": "Einföld vog, upp og niður",
        "excerpt": "Lagaútdráttur (8 til 16 taktar)",
        "dynamics": "Dynamics: byrja mjúkt, enda hátt",
        "spoken_phrase": "Ein töluð setning, svo Suno geti lesið raddhljóminn þinn"
      },
      "expectations": {
        "title": "Það sem Suno býst við",
        "body": "WAV, 48 kHz, mónó, þurrt (engin reverb eða áhrif), 3 til 5 mínútna viðmiðun. Hreinustu, dæmigerðustu 2 mínúturnar af tökunni gefa venjulega bestan árangur."
      }
    }
  },
  "status": {
