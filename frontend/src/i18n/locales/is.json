  "scripts": {
    "suno_voice_full": {
      "name": "Fullt raddhandrit fyrir Suno",
      "desc": "5 mínútur með leiðsögn: upphitun, sérhljóðar, tónstigar, tvö lagabrot, dýnamík og talað setning."
    },
    "step": {
      "warmup": "Raddupphitun",
      "warmup_inst": "Losaðu þig um með geispum, varatrillum (brrr) og mjúku suð í um það bil eina mínútu. Engin þörf á að taka upp - það er bara að slaka á hálsinum áður en þú syngur.",
      "vowels": "Viðvarandi sérhljóðar",
      "vowels_inst": "Haltu hverju sérhljóði - a, e, i, o, u - í 3 til 4 sekúndur á þægilegum tónhæð, með jöfnum hljóðstyrk. Þetta hjálpar Suno að taka upp hreinan tón röddarinnar þinnar.",
      "scales": "Skalar upp og niður",
      "scales_inst": "Syngdu einfaldan tónstiga upp og svo niður, á \"la\" eða \"na\". Það þarf ekki að vera fullkomið - markmiðið er að kortleggja raddsviðið þitt.",
      "section": "Lagaútdráttur - 1. hluti",
      "section_inst": "Syngdu 8 til 16 takta af laginu, með raunverulegan ásetning sem þú vilt koma á framfæri. Forgangsraða skýrleika og nærveru fram yfir tæknilega fullkomnun.",
      "section2": "Lagaútdráttur - hluti 2",
      "section2_inst": "Syngdu 8 til 16 takta í viðbót - helst kór eða kafla sem er andstæður þeim fyrri. Meiri fjölbreytni hjálpar fyrirsætunni að læra röddina þína.",
      "dynamics": "Dynamics: mjúkt → hátt",
      "dynamics_inst": "Syngdu sömu setninguna sem byrjar mjög mjúkt og endar hátt, án þess að þenja hálsinn. Þetta sýnir kraftmikið svið röddarinnar Suno.",
      "spoken": "Töluð setning",
      "spoken_inst": "Talaðu — ekki syngja — stutta, náttúrulega setningu, eins og þú værir að spjalla. Þetta hjálpar Suno að þekkja raunverulegan tón röddarinnar þinnar."
    }
