  "scripts": {
    "suno_voice_full": {
      "name": "Skrip vokal lengkap kanggo Suno",
      "desc": "5 menit sing dipandu: pemanasan, vokal, skala, rong cuplikan tembang, dinamika, lan frasa lisan."
    },
    "step": {
      "warmup": "Pemanasan vokal",
      "warmup_inst": "Loosen munggah karo yawns, lip trills (brrr), lan hum alus kanggo bab siji menit. Ora perlu ngrekam - mung kanggo ngendhokke tenggorokan sadurunge nyanyi.",
      "vowels": "Vokal lestari",
      "vowels_inst": "Tahan saben vokal - a, e, i, o, u - kanggo 3 nganti 4 detik ing nada sing nyaman, kanthi volume sing tetep. Iki mbantu Suno milih timbre murni saka swara sampeyan.",
      "scales": "Timbangan munggah lan mudhun",
      "scales_inst": "Sing ukuran prasaja munggah banjur mudhun, ing \"la\" utawa \"na\". Ora perlu sampurna - tujuane kanggo ngepetake jangkauan vokal sampeyan.",
      "section": "Kutipan tembang - part 1",
      "section_inst": "Nyanyi 8 nganti 16 bar lagu kasebut, kanthi tujuan sing bener sing pengin dikandhakake. Utamakan kejelasan lan ngarsane tinimbang kesempurnaan teknis.",
      "section2": "Kutipan tembang - part 2",
      "section2_inst": "Nyanyi liyane 8 nganti 16 bar - saenipun paduan suara utawa bagean sing kontras karo sing sadurunge. Macem-macem liyane mbantu model sinau swara sampeyan.",
      "dynamics": "Dinamika: alus → banter",
      "dynamics_inst": "Nyanyi frasa sing padha diwiwiti kanthi alus lan dipungkasi kanthi banter, tanpa ketegangan tenggorokan. Iki nuduhake Suno jangkauan dinamis swara sampeyan.",
      "spoken": "Frasa sing diucapake",
      "spoken_inst": "Ngomong - aja nyanyi - tembung sing cendhak lan alami, kaya sampeyan lagi ngobrol. Iki mbantu Suno ngerteni timbre asli swara sampeyan."
    }
  },
