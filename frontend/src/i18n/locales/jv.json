  "guide": {
    "title": "Panuntun ngrekam Suno",
    "subtitle": "Carane njupuk swara lan gitar njupuk sing njaluk asil paling apik.",
    "intro": "Suno nindakake paling apik kanthi referensi sing resik lan ora ambigu. Pandhuan iki nyakup persiapan, level target, lan skrip rekaman 3-5 menit.",
    "sections": {
      "prep": {
        "title": "Persiapan",
        "body": "Rekam ing kamar sing dirawat utawa sing akeh bahan alus (gorden, karpet, sandhangan ing lemari). Pateni penggemar lan apa wae sing hums. Anget swara nganti 5 menit sadurunge ngrekam."
      },
      "levels": {
        "title": "Tingkat: -12 kanggo -6 dBFS",
        "body": "Tujuane kanggo puncak antarane -12 lan -6 dBFS ing meter. Ing ngisor kisaran kasebut, swara latar mburi dadi luwih katon; ndhuwur iku, resiko clipping mundhak. Gunakake meter ing kaca Rekam kanggo nyetel gain sadurunge sampeyan miwiti."
      },
      "distance": {
        "title": "Jarak mic: 15-30 cm",
        "body": "Tetep 15 nganti 30 cm saka mikropon. Luwih cedhak tinimbang exaggerates plosives lan efek jarak; luwih adoh njupuk luwih reverb kamar lan gangguan."
      },
      "script": {
        "title": "Skrip rekaman",
        "warmup": "Pemanasan vokal (1-2 menit)",
        "vowels": "Vokal lestari - a, e, i, o, u",
        "scales": "Timbangan prasaja, munggah lan mudhun",
        "excerpt": "Kutipan lagu (8 nganti 16 bar)",
        "dynamics": "Dinamika: wiwitan alus, pungkasan banter",
        "spoken_phrase": "Siji frase sing diucapake, supaya Suno bisa maca nada vokal sampeyan"
      },
      "expectations": {
        "title": "Apa sing dikarepake Suno",
        "body": "WAV, 48 kHz, mono, garing (ora reverb utawa efek), 3 kanggo 5 menit referensi. 2 menit sing paling resik lan paling representatif biasane ngasilake asil sing paling apik."
      }
    }
  },
  "status": {
