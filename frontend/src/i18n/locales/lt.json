  "guide": {
    "title": "Suno įrašymo vadovas",
    "subtitle": "Kaip užfiksuoti balsą ir gitarą, gaunami geriausi rezultatai.",
    "intro": "„Suno“ geriausiai veikia su aiškiomis, nedviprasmiškomis nuorodomis. Šiame vadove aprašomas pasiruošimas, tiksliniai lygiai ir 3–5 minučių trukmės įrašymo scenarijus.",
    "sections": {
      "prep": {
        "title": "Pasiruošimas",
        "body": "Įrašykite apdorotoje patalpoje arba tokioje, kurioje yra daug minkštos medžiagos (užuolaidos, kilimėliai, drabužiai spintoje). Išjunkite ventiliatorius ir viską, kas ūžia. Prieš įrašydami pašildykite balsą 5 minutes."
      },
      "levels": {
        "title": "Lygiai: nuo -12 iki -6 dBFS",
        "body": "Siekite, kad matuoklis būtų nuo -12 iki -6 dBFS. Žemiau šio diapazono foninis triukšmas tampa labiau pastebimas; virš jo padidėja kirpimo rizika. Prieš pradėdami, naudokite matuoklį įrašymo puslapyje, kad nustatytumėte padidėjimą."
      },
      "distance": {
        "title": "Mikrofono atstumas: 15–30 cm",
        "body": "Būkite 15–30 cm atstumu nuo mikrofono. Arčiau nei tai perdeda sprogstamąsias medžiagas ir artumo efektą; toliau paima daugiau kambario reverb ir triukšmo."
      },
      "script": {
        "title": "Įrašymo scenarijus",
        "warmup": "Balso apšilimas (1-2 min.)",
        "vowels": "Ilgalaikiai balsiai - a, e, i, o, u",
        "scales": "Paprastos svarstyklės, aukštyn ir žemyn",
        "excerpt": "Dainos ištrauka (8–16 taktų)",
        "dynamics": "Dinamika: pradėkite tyliai, baigkite garsiai",
        "spoken_phrase": "Viena ištarta frazė, kad Suno galėtų perskaityti jūsų balso toną"
