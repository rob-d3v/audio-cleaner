  "guide": {
    "title": "Suno īrokstu ceļveds .",
    "subtitle": "Kai ītvert bolsu i gitaru jem, ka daboj lobuokūs rezultatus.",
    "intro": "Suno vyslobuok struodoj ar teirom, naskaidrom atsaucem. Itys ceļveds aptver sagataveišonu, mierķa leimini i 3–5 minotu īroksta scenareju.",
    "sections": {
      "prep": {
        "title": "Sagatavuošona .",
        "body": "Īroksts apstruoduotā telpā voi taidā, kur ir daudz meiksta materiala (aizkori, pakluoju, drēbis skapā). Izslēdz ventilatorus i vysu, kas dzīd. Pyrms īroksta 5 minotys sasiļdeit bolsu."
      },
      "levels": {
        "title": "Leimini: -12 līdz -6 dBFS",
        "body": "Mierkis ir viersyunis storp -12 i -6 dBFS iz skaiteituoja. Zam tuo diapazona fona trūksnis palīk radzamuoks; viers tuo, pīaug apgrīzšonys risks. Izmontojit skaiteituoju Īroksta lopā, kab pyrma suokuma īstateitu sovu pīaugumu."
      },
      "distance": {
        "title": "Mikrofona attālums: 15–30 cm",
        "body": "Palic 15 leidz 30 cm nu mikrofona. Tyvuok par tū puorspīļoj plozivus i tyvuma efektu; tuoļuok pījam vairuok ustobys atskaņu i trūksni."
      },
