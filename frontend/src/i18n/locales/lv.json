  "guide": {
    "title": "Suno ierakstīšanas ceļvedis",
    "subtitle": "Balss un ģitāras uzņemšana, kas nodrošina vislabākos rezultātus.",
    "intro": "Suno vislabāk darbojas ar tīrām, nepārprotamām atsaucēm. Šajā rokasgrāmatā ir aprakstīta sagatavošanās, mērķa līmeņi un 3–5 minūšu ierakstīšanas skripts.",
    "sections": {
      "prep": {
        "title": "Sagatavošana",
        "body": "Ierakstiet apstrādātā telpā vai telpā, kurā ir daudz mīksta materiāla (aizkari, paklāji, drēbes skapī). Izslēdziet ventilatorus un visu, kas dūko. Pirms ierakstīšanas iesildiet savu balsi 5 minūtes."
      },
      "levels": {
        "title": "Līmeņi: -12 līdz -6 dBFS",
        "body": "Mērītāja mērķis ir sasniegt maksimumus no -12 līdz -6 dBFS. Zem šī diapazona fona troksnis kļūst pamanāmāks; virs tā palielinās apgriešanas risks. Izmantojiet mērītāju lapā Ieraksts, lai iestatītu pieaugumu pirms darba sākšanas."
      },
      "distance": {
        "title": "Mikrofona attālums: 15–30 cm",
        "body": "Palieciet 15 līdz 30 cm attālumā no mikrofona. Tuvāk nekā tas pārspīlē sprāgstvielas un tuvuma efektu; tālāk uztver vairāk telpas reverb un trokšņu."
      },
      "script": {
