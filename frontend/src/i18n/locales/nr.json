  "guide": {
    "title": "Umhlahlandlela wokurekhoda we-Suno",
    "subtitle": "Indlela yokubamba iphimbo negitare elithathako elifumana imiphumela emihle khulu.",
    "intro": "I-Suno yenza ngcono khulu ngeenkhombo ezihlanzekileko, ezingakacaci. Umhlahlandlela lo uhlanganisa ukulungiselela, amazinga ahlosiweko, kanye neskripthi sokurekhoda semizuzu emi-3 ukuya kwemihlanu.",
    "sections": {
      "prep": {
        "title": "Ukuzilungiselela",
        "body": "Rekhoda ngaphakathi kwegumbi elilungisiweko nofana elinezinto ezinengi ezithambileko (amakhetheni, amathawula, izambatho ezisekhabetheni). Cima abalandeli nanyana yini edumako. Futhumeza ilizwi lakho imizuzu emi-5 ngaphambi kokurekhoda."
      },
      "levels": {
        "title": "Amazinga: -12 ukuya ku-6 dBFS",
        "body": "Hlosa iinqophiso eziphakathi kwe-12 ne-6 dBFS emitha. Ngaphasi kwalelo banga, umsindo wangemuva uyabonakala khulu; ngaphezulu kwayo, ubungozi bokusika bukhuphuka. Sebenzisa imitha ekhasini leRekhodi ukusetha inzuzo yakho ngaphambi kokuthi uthome."
      },
      "distance": {
        "title": "Ibanga le-mic: 15-30 cm",
        "body": "Hlala 15 ukuya ku-30 cm ukusuka kumakrofoni. Ukutjhidela kunalokho kukhuphula ama-plosives kanye nomphumela wokusondelana; ukude kuthatha ukuduma okukhulu kwegumbi nomsindo."
      },
      "script": {
        "title": "Ukurekhoda iskripthi",
