    "suno_voice_full": {
      "name": "Zolemba zonse za Suno",
      "desc": "Mphindi 5 zowongolera: kutenthetsa, mavawelo, masikelo, mawu awiri a nyimbo, mphamvu, ndi mawu oyankhulidwa."
    },
    "step": {
      "warmup": "Kutentha kwa mawu",
      "warmup_inst": "Masulani ndi kuyasamula, lip trills (brrr), ndi kung'ung'udza kofewa kwa mphindi imodzi. Palibe chifukwa chojambulira - ndikungopumula pakhosi musanayimbe.",
      "vowels": "Mavawelo okhazikika",
      "vowels_inst": "Gwirani mavawelo aliwonse - a, e, i, o, u - kwa masekondi 3 mpaka 4 pamawu anu omasuka, ndi voliyumu yokhazikika. Izi zimathandiza Suno kunyamula mawu anu.",
      "scales": "Mamba mmwamba ndi pansi",
      "scales_inst": "Imbani sikelo yosavuta mmwamba kenako pansi, pa \"la\" kapena \"na\". Sichiyenera kukhala changwiro - cholinga ndikujambula mawu anu.",
      "section": "Chigawo cha nyimbo - Gawo 1",
      "section_inst": "Imbani mipiringidzo 8 mpaka 16 ya nyimboyo, ndi cholinga chenicheni chomwe mukufuna kufotokoza. Ikani patsogolo kumveka bwino ndi kupezeka kuposa luso laukadaulo.",
      "section2": "Chigawo cha nyimbo - Gawo 2",
      "section2_inst": "Imbani mipiringidzo ina 8 mpaka 16 - korasi kapena gawo lomwe limasiyana ndi loyambalo. Kusiyanasiyana kowonjezereka kumathandizira chitsanzo kuphunzira mawu anu.",
      "dynamics": "Mphamvu: zofewa → mokweza",
      "dynamics_inst": "Imbani mawu omwewo kuyambira mofewa kwambiri ndikumaliza mokweza, osagwira khosi lanu. Izi zikuwonetsa Suno kuchuluka kwa mawu anu.",
      "spoken": "Mawu olankhulidwa",
      "spoken_inst": "Lankhulani - osayimba - mawu achidule, achilengedwe, ngati mukucheza. Izi zimathandiza Suno kuzindikira momwe mawu anu amamvekera."
    }
