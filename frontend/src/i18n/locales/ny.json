  "guide": {
    "title": "Suno kujambula kalozera",
    "subtitle": "Momwe mungajambulire mawu ndi gitala zimatengera zotsatira zabwino kwambiri.",
    "intro": "Suno imagwira bwino ntchito ndi maulalo oyera, osadziwika bwino. Bukhuli likukhudza kukonzekera, milingo yomwe mukufuna, ndi zolemba zojambulira mphindi 3-5.",
    "sections": {
      "prep": {
        "title": "Kukonzekera",
        "body": "Lembani m'chipinda chokhalamo kapena chokhala ndi zinthu zambiri zofewa (makatani, makapu, zovala mu chipinda). Zimitsani mafani ndi chilichonse chomwe chimang'ung'udza. Kutenthetsa mawu anu kwa mphindi 5 musanajambule."
      },
      "levels": {
        "title": "Miyezo: -12 mpaka -6 dBFS",
        "body": "Cholinga cha nsonga zapakati pa -12 ndi -6 dBFS pa mita. Pansi pa mzerewu, phokoso lakumbuyo limawonekera kwambiri; pamwamba pake, chiwopsezo chodula chimakwera. Gwiritsani ntchito mita patsamba la Record kuti mukhazikitse phindu lanu musanayambe."
      },
      "distance": {
        "title": "Kutalika kwa mic: 15-30 cm",
        "body": "Khalani 15 mpaka 30 cm kuchokera pa maikolofoni. Pafupi kuposa pamenepo amakokomeza plosives ndi moyandikana zotsatira; Kutaliko kumangotenga mavesi owonjezera ndi phokoso."
      },
      "script": {
        "title": "Kujambulira script",
        "warmup": "Kutentha kwa mawu (1-2 mphindi)",
        "vowels": "Mavawelo okhazikika - a, e, i, o, u",
        "scales": "Mamba osavuta, mmwamba ndi pansi",
        "excerpt": "Chigawo chanyimbo (mipiringidzo 8 mpaka 16)",
        "dynamics": "Mphamvu: Yambani mofewa, maliza mokweza",
        "spoken_phrase": "Mawu amodzi, kuti Suno athe kuwerenga kamvekedwe kanu ka mawu"
      },
      "expectations": {
        "title": "Zomwe Suno amayembekezera",
        "body": "WAV, 48 kHz, mono, youma (palibe reverb kapena zotsatira), 3 mpaka 5 mphindi zofotokozera. Ukhondo kwambiri, woyimilira kwambiri mphindi ziwiri zakutenga nthawi zambiri zimatulutsa zotsatira zabwino kwambiri."
      }
    }
