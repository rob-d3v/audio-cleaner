  "guide": {
    "title": "Suno grabacionmanta pusaq",
    "subtitle": "Imaynatataq kunkata hap’inapaq guitarratapas hap’inapaq chaykunan aswan allin ruwaykunata tarinku.",
    "intro": "Suno aswan allinta ruwan chuya, mana iskayrayaq referenciakunawan. Kay yanapakuyqa wakichiymanta, meta niveles nisqamanta, 3–5 minuto grabacion guionmanta ima riman.",
    "sections": {
      "prep": {
        "title": "Wakichiy",
        "body": "Grabay huk hampisqa cuartopi utaq achka llampu materialniyuq (cortinakuna, alfombrakuna, armariopi pachakuna). Ventiladores nisqakunata, imapas zumbikuqtapas wañuchiy. Manaraq grabachkaspa 5 minuto kunkaykita q’uñichiy."
      },
      "levels": {
        "title": "Niveles: -12manta -6 dBFSkama",
        "body": "Chay mitrupi -12manta -6 dBFSkama picos nisqakunata maskay. Chay rango urapi, qhipaman qapariy aswan reparakun; chaypa hawanpiqa, riesgo de clipping nisqa wicharin. Grabar paginapi medidorwan gananciaykita churanaykipaq manaraq qallarichkaspa."
      },
      "distance": {
        "title": "Mic karun: 15–30 cm",
        "body": "Microfonomanta 15manta 30 cmkama qhipakuy. Aswan qaylla chaymantaqa exageran plosivos nisqakunata hinallataq efecto de proximidad nisqakunata; aswan karu karupiqa aswan cuarto reverberaciónta hinaspa ruyrutapas huñun."
      },
      "script": {
        "title": "Grabacionmanta guion",
        "warmup": "Kunka q'uñichiy (1–2 minutu) .",
        "vowels": "Sustentasqa kunkakuna — a, e, i, o, u",
