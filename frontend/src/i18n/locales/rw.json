  "guide": {
    "title": "Igitabo cyo gufata amajwi ya Suno",
    "subtitle": "Nigute ushobora gufata amajwi na gitari bifata ibisubizo byiza.",
    "intro": "Suno akora neza hamwe nibisobanuro bisobanutse, bidasobanutse. Aka gatabo gakubiyemo imyiteguro, urwego rwerekanwe, hamwe niminota 3-5 yo gufata amajwi.",
    "sections": {
      "prep": {
        "title": "Kwitegura",
        "body": "Andika mucyumba cyavuwe cyangwa kimwe gifite ibikoresho byinshi byoroshye (umwenda, ibitambaro, imyenda mu kabati). Zimya abafana nibintu byose bisetsa. Shyushya ijwi mu minota 5 mbere yo gufata amajwi."
      },
      "levels": {
        "title": "Urwego: -12 kugeza -6 dBFS",
        "body": "Intego yimpinga hagati ya -12 na -6 dBFS kuri metero. Munsi yurwo rwego, urusaku rwinyuma ruragaragara cyane; hejuru yacyo, gukuramo ibyago biriyongera. Koresha metero kurupapuro rwanditse kugirango ushireho inyungu mbere yuko utangira."
      },
      "distance": {
        "title": "Intera nto: cm 15-30",
        "body": "Gumana cm 15 kugeza 30 kuri mikoro. Hafi yibyo gukabiriza plosives ningaruka zegeranye; kure cyane itora ibyumba byinshi reverb n urusaku."
      },
      "script": {
        "title": "Kwandika",
        "warmup": "Gushyushya amajwi (iminota 1-2)",
        "vowels": "Inyajwi zirambye - a, e, i, o, u",
        "scales": "Umunzani woroshye, hejuru no hepfo",
        "excerpt": "Igice cy'indirimbo (8 kugeza 16)",
        "dynamics": "Ibikorwa: tangira byoroshye, urangize cyane",
        "spoken_phrase": "Imvugo imwe ivugwa, kugirango Suno asome amajwi yawe"
      },
      "expectations": {
        "title": "Ibyo Suno yiteze",
        "body": "WAV, 48 kHz, mono, yumye (nta reverb cyangwa ingaruka), iminota 3 kugeza kuri 5 yerekana. Isuku, ihagarariwe cyane iminota 2 yo gufata mubisanzwe itanga ibisubizo byiza."
      }
    }
  },
