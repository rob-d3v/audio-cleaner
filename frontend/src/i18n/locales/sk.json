  "guide": {
    "title": "Sprievodca nahrávaním Suno",
    "subtitle": "Ako zachytiť hlas a gitaru, aby ste dosiahli najlepšie výsledky.",
    "intro": "Suno najlepšie funguje s čistými, jednoznačnými referenciami. Táto príručka zahŕňa prípravu, cieľové úrovne a 3–5 minútový záznamový scenár.",
    "sections": {
      "prep": {
        "title": "Príprava",
        "body": "Nahrávajte v ošetrenej miestnosti alebo v miestnosti s množstvom mäkkého materiálu (záclony, koberčeky, oblečenie v skrini). Vypnite ventilátory a všetko, čo hučí. Pred nahrávaním zahrejte svoj hlas 5 minút."
      },
      "levels": {
        "title": "Úrovne: -12 až -6 dBFS",
        "body": "Zamerajte sa na špičky medzi -12 a -6 dBFS na merači. Pod týmto rozsahom je hluk pozadia zreteľnejší; nad ním stúpa riziko orezania. Použite glukomer na stránke Record na nastavenie vášho zisku predtým, ako začnete."
      },
      "distance": {
        "title": "Vzdialenosť mikrofónu: 15–30 cm",
        "body": "Zostaňte 15 až 30 cm od mikrofónu. Bližšie ako to preháňa výbušniny a efekt blízkosti; ďalej zachytí viac priestorového dozvuku a hluku."
      },
      "script": {
        "title": "Nahrávací skript",
        "warmup": "Zahriatie hlasu (1–2 minúty)",
        "vowels": "Trvalé samohlásky — a, e, i, o, u",
