  "guide": {
    "title": "Vodnik za snemanje Suno",
    "subtitle": "Kako zajeti glas in kitaro, da dobite najboljše rezultate.",
    "intro": "Suno najbolje deluje s čistimi, nedvoumnimi referencami. Ta vodnik zajema pripravo, ciljne ravni in 3–5 minutni snemalni scenarij.",
    "sections": {
      "prep": {
        "title": "Priprava",
        "body": "Snemajte v obdelanem prostoru ali v prostoru z veliko mehkega materiala (zavese, preproge, oblačila v omari). Izklopite ventilatorje in vse, kar brni. Pred snemanjem 5 minut ogrevajte glas."
      },
      "levels": {
        "title": "Stopnje: -12 do -6 dBFS",
        "body": "Ciljajte na vrhove med -12 in -6 dBFS na merilniku. Pod tem obsegom postane hrup v ozadju bolj opazen; nad njo se poveča tveganje odreza. Uporabite merilnik na strani Record, da nastavite dobiček, preden začnete."
      },
      "distance": {
        "title": "Razdalja mikrofona: 15–30 cm",
        "body": "Ostanite 15 do 30 cm od mikrofona. Bližje od tega pretirava z eksplozivnostjo in učinkom bližine; dlje stran zajame več odmeva in hrupa v prostoru."
      },
      "script": {
        "title": "Snemalni scenarij",
        "warmup": "Vokalno ogrevanje (1–2 minuti)",
        "vowels": "Trajni samoglasniki — a, e, i, o, u",
        "scales": "Preproste lestvice, gor in dol",
        "excerpt": "Odlomek pesmi (8 do 16 taktov)",
        "dynamics": "Dinamika: začetek mehak, konec glasen",
        "spoken_phrase": "Ena izgovorjena fraza, tako da lahko Suno prebere vaš vokalni ton"
      },
      "expectations": {
        "title": "Kaj Suno pričakuje",
        "body": "WAV, 48 kHz, mono, suho (brez odjeka ali učinkov), 3 do 5 minut referenčnega zvoka. Najbolj čiste, najbolj reprezentativne 2 minuti posnetka običajno dajejo najboljše rezultate."
      }
    }
  },
