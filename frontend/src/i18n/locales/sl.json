  "scripts": {
    "suno_voice_full": {
      "name": "Celoten vokalni scenarij za Suno",
      "desc": "5 vodenih minut: ogrevanje, samoglasniki, lestvice, dva odlomka pesmi, dinamika in govorjeni stavek."
    },
    "step": {
      "warmup": "Vokalno ogrevanje",
      "warmup_inst": "Približno minuto se sprostite z zehanjem, trljanjem ustnic (brrr) in tihim brenčanjem. Ni potrebe po snemanju — le za sprostitev grla pred petjem.",
      "vowels": "Trajni samoglasniki",
      "vowels_inst": "Držite vsak samoglasnik – a, e, i, o, u – 3 do 4 sekunde na vaši udobni višini in z enakomerno glasnostjo. To pomaga Sunu zaznati čisti ton vašega glasu.",
      "scales": "Lestvice gor in dol",
