  "guide": {
    "title": "Suno rekodhi gwara",
    "subtitle": "Maitiro ekutora izwi uye gitare zvinotora izvo zvinowana zvakanakisa mhedzisiro.",
    "intro": "Suno anoita zvakanyanya neakachena, mareferensi asina kujeka. Gwaro iri rinobata gadziriro, nhanho dzetariro, uye 3-5 maminetsi ekurekodha script.",
    "sections": {
      "prep": {
        "title": "Kugadzirira",
        "body": "Nyora muimba yakarapwa kana imwe ine zvinhu zvakawanda zvakapfava (maketeni, machira, zvipfeko muwadhiropu). Dzima mafeni uye chero chinhu chinonzwika. Dziyisa izwi rako kwemaminitsi mashanu usati warekodha."
      },
      "levels": {
        "title": "Nhamba: -12 kusvika -6 dBFS",
        "body": "Vavarira kukwirira kuri pakati pe -12 ne -6 dBFS pamamita. Pazasi penzvimbo iyi, ruzha rwekumashure rwunonyanya kuoneka; pamusoro payo, kudonha njodzi inokwira. Shandisa mita paRekodha peji kuti uise kuwana kwako usati watanga."
      },
      "distance": {
        "title": "Mic kure: 15-30 cm",
        "body": "Gara 15 kusvika 30 cm kubva kumakrofoni. Pedyo kupfuura iyo inowedzeredza plosives uye proximity effect; kure kure anotora mamwe kamuri reverb uye ruzha."
      },
      "script": {
        "title": "Kurekodha script",
        "warmup": "Kudziya kwezwi (1-2 maminitsi)",
        "vowels": "Mavhawero akasimba - a, e, i, o, u",
        "scales": "Zviyero zviri nyore, kumusoro uye pasi",
        "excerpt": "Chidimbu cherwiyo (8 kusvika 16 mabara)",
        "dynamics": "Dynamics: tanga zvinyoro, kupera zvine ruzha",
        "spoken_phrase": "Mutsara mumwe chete unotaurwa, kuti Suno averenge inzwi rako"
      },
      "expectations": {
        "title": "Zvinotarisirwa naSuno",
        "body": "WAV, 48 kHz, mono, yakaoma (hapana reverb kana mhedzisiro), 3 kusvika ku5 maminetsi ereferensi. Iyo yakachena, yakawanda inomiririra 2 maminetsi ekutora kazhinji inoburitsa zvakanakisa mhedzisiro."
      }
    }
  },
