  "scripts": {
    "suno_voice_full": {
      "name": "Runyoro rwakazara rwezwi reSuno",
      "desc": "Maminitsi mashanu anotungamirwa: kudziya, mavhawero, zvikero, zvinyorwa zviviri zvenziyo, simba, uye mutsara unotaurwa."
    },
    "step": {
      "warmup": "Vocal warm-up",
      "warmup_inst": "Sunungura nekuzamura, lip trills (brrr), uye hum yakapfava kweinenge miniti. Hapana chikonzero chekurekodha - kungozorodza huro yako usati waimba.",
      "vowels": "Mavhawero akasimba",
      "vowels_inst": "Bata mavhawero ega ega - a, e, i, o, u - kwemasekonzi matatu kusvika mana painzwi rako rakanaka, nevhoriyamu yakatsiga. Izvi zvinobatsira Suno kuti atore ruzha rweizwi rako.",
      "scales": "Zvikero kumusoro nekudzika",
      "scales_inst": "Imba chikero chiri nyore kumusoro uye pasi, pa \"la\" kana \"na\". Izvo hazvidi kuve akakwana - chinangwa ndechekumepu yako yezwi.",
      "section": "Chidimbu cherwiyo - chikamu 1",
