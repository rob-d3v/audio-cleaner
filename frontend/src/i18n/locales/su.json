  "scripts": {
    "suno_voice_full": {
      "name": "Aksara vokal pinuh pikeun Suno",
      "desc": "5 menit terpandu: haneut-up, vokal, skala, dua cutatan lagu, dinamika, jeung frasa lisan."
    },
    "step": {
      "warmup": "Pemanasan vokal",
      "warmup_inst": "Loosen up kalawan yawns, trills lip (brrr), sarta hum lemes salila kira hiji menit. Henteu kedah ngarékam - éta ngan ukur bersantai tikoro sateuacan nyanyi.",
      "vowels": "Vokal sustained",
      "vowels_inst": "Tahan unggal vokal - a, e, i, o, u - pikeun 3 nepi ka 4 detik dina pitch nyaman Anjeun, kalawan volume ajeg. Ieu ngabantuan Suno milih nada murni tina sora anjeun.",
      "scales": "Timbangan luhur jeung ka handap",
      "scales_inst": "Nyanyi skala basajan ka luhur lajeng ka handap, dina \"la\" atawa \"na\". Henteu kedah sampurna - tujuanana nyaéta pikeun memetakan rentang vokal anjeun.",
      "section": "Petikan lagu - bagian 1",
      "section_inst": "Nyanyi 8 nepi ka 16 bar lagu, kalawan niat sabenerna rék ditepikeun. Prioritaskeun kajelasan sareng ayana tibatan kasampurnaan téknis.",
      "section2": "Petikan lagu - bagian 2",
      "section2_inst": "Nyanyi deui 8 nepi ka 16 bar - ideally chorus atawa bagian nu kontras jeung saméméhna. Langkung seueur variasi ngabantosan modél diajar sora anjeun.",
