  "guide": {
    "title": "Pituduh rékaman Suno",
    "subtitle": "Kumaha néwak sora sareng gitar nyandak éta kéngingkeun hasil anu pangsaéna.",
    "intro": "Suno ngalaksanakeun pangalusna kalawan bersih, rujukan unambiguous. Pituduh ieu nyertakeun persiapan, tingkat target, sareng naskah rekaman 3-5 menit.",
    "sections": {
      "prep": {
        "title": "Persiapan",
        "body": "Rékam di kamar anu dirawat atanapi anu seueur bahan lemes (gorden, karpét, baju dina lomari). Pareuman kipas sareng naon waé anu hums. Panaskeun sora anjeun 5 menit sateuacan ngarékam."
      },
      "levels": {
        "title": "Tingkat: -12 nepi ka -6 dBFS",
        "body": "Tujuan pikeun puncak antara -12 sareng -6 dBFS dina méter. Handapeun rentang éta, noise latar jadi leuwih noticeable; luhureun eta, résiko clipping naék. Anggo méter dina halaman Rékam pikeun nyetél kauntungan anjeun sateuacan ngamimitian."
      },
      "distance": {
        "title": "Jarak mic: 15–30 cm",
        "body": "Tetep 15 nepi ka 30 cm tina mikropon. Ngadeukeutan ti nu exaggerates plosives jeung pangaruh jarak; leuwih jauh nyokot leuwih reverb kamar jeung noise."
      },
      "script": {
        "title": "Ngarékam naskah",
        "warmup": "Pemanasan vokal (1-2 menit)",
        "vowels": "Vokal sustained - a, e, i, o, u",
        "scales": "Skala basajan, luhur jeung ka handap",
        "excerpt": "Kutipan lagu (8 nepi ka 16 bar)",
        "dynamics": "Dinamika: mimiti lemes, tungtung nyaring",
        "spoken_phrase": "Hiji frasa anu diucapkeun, ku kituna Suno tiasa maca nada vokal anjeun"
      },
      "expectations": {
        "title": "Naon Suno ekspektasi",
        "body": "WAV, 48 kHz, mono, garing (euweuh reverb atawa épék), 3 nepi ka 5 menit rujukan. The cleanest, paling wawakil 2 menit nyokot biasana ngahasilkeun hasil pangalusna."
      }
    }
  },
  "status": {
    "idea": "Gagasan",
