  "scripts": {
    "suno_voice_full": {
      "name": "Suno'nun tam vokal senaryosu",
      "desc": "5 rehberli dakika: ısınma, sesli harfler, diziler, iki şarkı alıntısı, dinamikler ve sözlü bir ifade."
    },
    "step": {
      "warmup": "Vokal ısınma",
      "warmup_inst": "Yaklaşık bir dakika boyunca esneme, dudak titremesi (brrr) ve yumuşak bir uğultu ile gevşeyin. Kaydetmeye gerek yok; sadece şarkı söylemeden önce boğazınızı rahatlatmak içindir.",
      "vowels": "Uzun sesli harfler",
      "vowels_inst": "Her sesli harfi - a, e, i, o, u - rahat ettiğiniz ses perdesinde ve sabit bir ses seviyesinde 3 ila 4 saniye boyunca tutun. Bu, Suno'nun sesinizin saf tınısını yakalamasına yardımcı olur.",
      "scales": "Yukarı ve aşağı ölçeklenir",
      "scales_inst": "\"La\" veya \"na\" ile basit bir yukarı ve aşağı ölçek söyleyin. Mükemmel olmasına gerek yok; amaç ses aralığınızın haritasını çıkarmaktır.",
      "section": "Şarkı alıntısı – bölüm 1",
      "section_inst": "İletmek istediğiniz gerçek niyetle şarkının 8 ila 16 ölçüsünü söyleyin. Teknik mükemmellik yerine netlik ve mevcudiyete öncelik verin.",
      "section2": "Şarkı alıntısı – bölüm 2",
      "section2_inst": "8 ila 16 ölçü daha söyleyin; ideal olarak bir koro veya bir öncekiyle tezat oluşturan bir bölüm. Daha fazla çeşitlilik, modelin sesinizi öğrenmesine yardımcı olur.",
      "dynamics": "Dinamikler: yumuşak → yüksek",
      "dynamics_inst": "Aynı cümleyi çok yumuşak başlayıp yüksek sesle, boğazınızı zorlamadan söyleyin. Bu Suno'ya sesinizin dinamik aralığını gösterir.",
      "spoken": "Sözlü ifade",
      "spoken_inst": "Sanki sohbet ediyormuş gibi kısa, doğal bir cümle konuşun - şarkı söylemeyin -. Bu, Suno'nun sesinizin gerçek tınısını tanımasına yardımcı olur."
    }
  },
