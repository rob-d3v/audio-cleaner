  "guide": {
    "title": "Suno yozish uchun qo'llanma",
    "subtitle": "Ovoz va gitara uchun qanday suratga olish mumkin, bu eng yaxshi natijalarni beradi.",
    "intro": "Suno toza, aniq havolalar bilan eng yaxshi ishlaydi. Ushbu qo'llanma tayyorgarlik, maqsadli darajalar va 3-5 daqiqalik yozish skriptini o'z ichiga oladi.",
    "sections": {
      "prep": {
        "title": "Tayyorgarlik",
        "body": "Yozib olingan xonada yoki juda ko'p yumshoq materiallar (pardalar, gilamlar, shkafdagi kiyimlar) bo'lgan xonada yozib oling. Muxlislarni va g'o'ng'illagan narsalarni o'chiring. Yozishdan oldin ovozingizni 5 daqiqa qizdiring."
      },
      "levels": {
        "title": "Darajalar: -12 dan -6 dBFS",
        "body": "Metrda -12 dan -6 dBFS gacha bo'lgan cho'qqilarga intiling. Ushbu diapazon ostida fon shovqini sezilarli bo'ladi; uning ustida, kesish xavfi ortadi. Ishni boshlashdan oldin daromadingizni belgilash uchun Yozuv sahifasidagi hisoblagichdan foydalaning."
      },
      "distance": {
        "title": "Mikrofon masofasi: 15-30 sm",
        "body": "Mikrofondan 15-30 sm masofada turing. Undan ko'ra yaqinroq portlovchi va yaqinlik ta'sirini oshirib yuboradi; uzoqroqda ko'proq xona reverb va shovqinni tanlaydi."
      },
      "script": {
        "title": "Yozib olish skripti",
        "warmup": "Ovozni isitish (1-2 daqiqa)",
        "vowels": "Barqaror unlilar — a, e, i, o, u",
        "scales": "Oddiy tarozi, yuqoriga va pastga",
        "excerpt": "Qo'shiqdan parcha (8-16 bar)",
        "dynamics": "Dinamik: yumshoq boshlanadi, baland ovozda tugaydi",
        "spoken_phrase": "Suno sizning ovoz ohangingizni o'qiy olishi uchun bitta og'zaki ibora"
      },
