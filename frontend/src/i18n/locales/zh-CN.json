  "scripts": {
    "suno_voice_full": {
      "name": "Suno 的完整声乐脚本",
      "desc": "5 分钟指导：热身、元音、音阶、两首歌曲摘录、力度和口语短语。"
    },
    "step": {
      "warmup": "声乐热身",
      "warmup_inst": "通过打哈欠、嘴唇颤音 (brrr) 和轻柔的嗡嗡声来放松大约一分钟。不需要录音——只是在唱歌之前放松一下喉咙。",
      "vowels": "延音元音",
      "vowels_inst": "以您舒适的音高和稳定的音量按住每个元音（a、e、i、o、u）3 到 4 秒。这有助于 Suno 拾取您声音的纯净音色。",
      "scales": "放大和缩小",
      "scales_inst": "在“la”或“na”上先唱简单的音阶，然后唱低音阶。它不需要完美——目标是映射您的音域。",
      "section": "歌曲摘录 — 第 1 部分",
      "section_inst": "唱歌曲的 8 到 16 小节，带着你想要传达的真实意图。优先考虑清晰度和表现而不是技术完美。",
      "section2": "歌曲摘录 — 第 2 部分",
      "section2_inst": "再唱 8 到 16 小节——最好是副歌部分或与前一个部分形成对比的部分。更多的多样性有助于模型学习你的声音。",
      "dynamics": "力度：柔和→响亮",
      "dynamics_inst": "唱同样的乐句，开头非常轻柔，结尾大声，不要拉紧喉咙。这向 Suno 显示了您声音的动态范围。",
      "spoken": "口语短语",
      "spoken_inst": "说话——不要唱歌——简短、自然的短语，就像你们在聊天一样。这有助于 Suno 识别您声音的真实音色。"
    }
  },
