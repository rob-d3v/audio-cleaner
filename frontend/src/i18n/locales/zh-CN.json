  "guide": {
    "title": "Suno录音指南",
    "subtitle": "如何捕捉人声和吉他片段以获得最佳效果。",
    "intro": "Suno 在干净、明确的参考文献中表现最佳。本指南涵盖准备工作、目标级别和 3-5 分钟的录音脚本。",
    "sections": {
      "prep": {
        "title": "准备工作",
        "body": "在经过处理的房间或有大量柔软材料（窗帘、地毯、壁橱里的衣服）的房间中录制。关掉风扇和任何嗡嗡声的东西。录音前先热身 5 分钟。"
      },
      "levels": {
        "title": "电平：-12 至 -6 dBFS",
        "body": "瞄准仪表上 -12 和 -6 dBFS 之间的峰值。低于该范围，背景噪音变得更加明显；高于该水平，削波风险就会上升。在开始之前，使用“记录”页面上的仪表设置增益。"
      },
      "distance": {
        "title": "麦克风距离：15–30 厘米",
        "body": "与麦克风保持 15 至 30 厘米的距离。比这更接近夸大爆破音和邻近效应；距离越远，房间混响和噪音就越多。"
      },
      "script": {
        "title": "录音脚本",
        "warmup": "声音热身（1-2 分钟）",
        "vowels": "延音元音 - a、e、i、o、u",
        "scales": "简单的刻度，向上和向下",
        "excerpt": "歌曲摘录（8 至 16 小节）",
        "dynamics": "动态：开始轻柔，结束响亮",
        "spoken_phrase": "一句口语短语，让 Suno 能够读懂您的语气"
      },
      "expectations": {
        "title": "苏诺的期望",
        "body": "WAV，48 kHz，单声道，干（无混响或效果），3 到 5 分钟的参考。最干净、最具代表性的 2 分钟镜头通常会产生最佳效果。"
      }
    }
  },
