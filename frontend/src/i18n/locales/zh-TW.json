  "guide": {
    "title": "Suno錄音指南",
    "subtitle": "如何捕捉人聲和吉他片段以獲得最佳效果。",
    "intro": "Suno 在乾淨、明確的參考文獻中表現最佳。本指南涵蓋準備工作、目標等級和 3-5 分鐘的錄音腳本。",
    "sections": {
      "prep": {
        "title": "準備工作",
        "body": "在經過處理的房間或有大量柔軟材料（窗簾、地毯、壁櫥裡的衣服）的房間中錄製。關掉風扇和任何嗡嗡聲的東西。錄音前熱身 5 分鐘。"
      },
      "levels": {
        "title": "電平：-12 至 -6 dBFS",
        "body": "瞄準儀表上 -12 和 -6 dBFS 之間的峰值。低於該範圍，背景噪音變得更加明顯；高於該水平，削波風險就會上升。在開始之前，使用「記錄」頁面上的儀表設定增益。"
      },
      "distance": {
        "title": "麥克風距離：15–30 厘米",
        "body": "與麥克風保持 15 至 30 公分的距離。比這更接近誇大爆破音和鄰近效應；距離越遠，房間混響和噪音就越多。"
      },
      "script": {
        "title": "錄音腳本",
        "warmup": "聲音熱身（1-2 分鐘）",
        "vowels": "延音元音 - a、e、i、o、u",
        "scales": "簡單的刻度，向上和向下",
        "excerpt": "歌曲摘錄（8 至 16 小節）",
        "dynamics": "動態：開始輕柔，結束響亮",
        "spoken_phrase": "一句口語短語，讓 Suno 能夠讀懂您的語氣"
      },
      "expectations": {
        "title": "蘇諾的期望",
        "body": "WAV，48 kHz，單聲道，乾（無混響或效果），3 到 5 分鐘的參考。最乾淨、最具代表性的 2 分鐘鏡頭通常會產生最佳效果。"
      }
    }
  },
